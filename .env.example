# ── IBM watsonx.ai ────────────────────────────────────────────────────────────
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=
# ── IBM Cloudant ──────────────────────────────────────────────────────────────
CLOUDANT_URL=
CLOUDANT_APIKEY=
# ── IBM Cloud Object Storage ──────────────────────────────────────────────────
COS_API_KEY=
COS_INSTANCE_CRN=
COS_BUCKET=
COS_ENDPOINT_URL=

# ── Optional tuning ───────────────────────────────────────────────────────────
# PARAPHRASE_COSINE_THRESHOLD=
# STYLE_DRIFT_THRESHOLD=
# APP_CORS_ORIGINS=

# ── Frontend (create frontend/.env from this) ─────────────────────────────────
VITE_API_BASE_URL=
APP_CORS_ORIGINS=
